# Application
APP_NAME=Floodline TN
APP_VERSION=1.0.0
ENVIRONMENT=development

# Data Source Toggle
USE_MOCK_DATA=true

# API Keys (leave empty for mock mode)
OPENWEATHER_API_KEY=
IMD_API_KEY=
CWC_API_KEY=

# Database
DATABASE_URL=sqlite:///./floodline.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Feature Flags
ENABLE_SHAP=true
ENABLE_RIVER_PROPAGATION=true
ENABLE_ALERTS=true
